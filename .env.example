# Storage
CRAWLEE_STORAGE_DIR=
CRAWLEE_LOCAL_STORAGE_DIR=

# Logging
CRAWLEE_LOG_LEVEL=INFO
CRAWLEE_DEBUG=0

# Browser
CRAWLEE_HEADLESS=1

# Default crawl budgets
CRAWLEE_DEFAULT_MAX_PAGES=20
CRAWLEE_DEFAULT_MAX_DEPTH=1
CRAWLEE_DEFAULT_HTTP_CONCURRENCY=5
CRAWLEE_DEFAULT_BROWSER_CONCURRENCY=2
CRAWLEE_DEFAULT_REQUEST_TIMEOUT_MS=30000
CRAWLEE_DEFAULT_TOTAL_TIMEOUT_MS=300000
CRAWLEE_MAX_RESPONSE_BYTES=5242880
CRAWLEE_MAX_FILE_BYTES=10485760

# Optional proxy (disabled by default)
CRAWLEE_PROXY_URLS=

# Experimental adapters (disabled by default)
CRAWLEE_STAGEHAND_ENABLED=false
